{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; npx @biomejs/biome check --write \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting with Biome..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm test && npx tsc --noEmit",
            "timeout": 30,
            "statusMessage": "Running tests & typecheck..."
          }
        ]
      }
    ]
  }
}
